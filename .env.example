# Cloudflare Web Analytics beacon token (Analytics & Logs -> Web Analytics -> Add a
# site -> playcydi.com, in the Cloudflare dashboard). Must be prefixed with VITE_ so
# Vite exposes it to index.html. Leave unset locally - the beacon only loads on the
# production hostnames anyway (see index.html).
VITE_CF_WEB_ANALYTICS_TOKEN=
