{
  "name": "cydi",
  "compatibility_date": "2026-07-07",
  "main": "worker/index.ts",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "kv_namespaces": [
    {
      // Shared drawings/challenges ONLY (see worker/index.ts share routes).
      "binding": "SHARE_KV",
      "id": "27ae6995fdef4040ac555ee8f1830bee"
    },
    {
      // Dynamic content catalog releases (content:catalog:<releaseId>,
      // content:active, content:releases) - deliberately separated from
      // SHARE_KV so content publishing can never touch user share data.
      // Real namespaces created 2026-07-22 on the playcydi Cloudflare
      // account (empty; wired here but not yet serving until deploy):
      //   id         -> production namespace
      //   preview_id -> `wrangler dev --remote` / preview deploys
      // `wrangler dev --local` ignores both and keys off the binding name.
      "binding": "CONTENT_KV",
      "id": "17ed84bd6bea49d08f6aad52c57c0952",
      "preview_id": "35365d9060f74390aad633564e0241ef"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "DAILY_CHALLENGE_DO",
        "class_name": "DailyChallengeDO"
      },
      {
        "name": "ANALYTICS_DO",
        "class_name": "AnalyticsDO"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["DailyChallengeDO"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["AnalyticsDO"]
    }
  ]
}
